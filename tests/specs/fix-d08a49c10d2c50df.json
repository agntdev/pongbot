[
  {
    "name": "unknown bot command replies only with fallback hint, not text fallback",
    "steps": [
      {
        "send": { "text": "/foobar" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Use /ping or /count."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "plain text message still triggers fallback",
    "steps": [
      {
        "send": { "text": "hello" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "I didn't understand that. Try /start to see what I can do."
            }
          }
        ]
      }
    ]
  }
]
